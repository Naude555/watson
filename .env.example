# ----------------------------
# Server
# ----------------------------
PORT=3000
NODE_ENV=development


# WhatsApp Web version behavior
# Force runtime fetch of latest supported WA Web version during connect.
WA_FORCE_LATEST_WEB_VERSION=1
# Optional hard override. Keep empty unless instructed for 405 recovery.
# Example: 2.3000.1035194821
WA_WEB_VERSION_OVERRIDE=

# ----------------------------
# Security
# ----------------------------
# Required for normal API calls (send endpoints). If empty, API is open (NOT recommended for VPS).
WA_API_KEY=change_me_to_a_secure_random_string
# Optional previous key(s) during rotation (comma-separated)
WA_API_KEY_PREVIOUS=

# Required for Admin API + Admin UI (/admin/*). If empty, admin features won't work.
WA_ADMIN_KEY=change_me_to_a_secure_random_string
# Optional previous key(s) during rotation (comma-separated)
WA_ADMIN_KEY_PREVIOUS=

# Optional operator key (can send/manage most operations but not sensitive admin changes)
WA_OPERATOR_KEY=
# Optional previous operator key(s) during rotation
WA_OPERATOR_KEY_PREVIOUS=

# Optional viewer key (read-only access)
WA_VIEWER_KEY=
# Optional previous viewer key(s) during rotation
WA_VIEWER_KEY_PREVIOUS=

# Optional admin IP allowlist (comma-separated, blank = disabled)
ADMIN_IP_ALLOWLIST=

# Admin CSRF cookie name (session-authenticated admin UI)
ADMIN_CSRF_COOKIE=wa_admin_csrf

# Admin audit log file + cap
ADMIN_AUDIT_FILE=/data/admin_audit.json
ADMIN_AUDIT_MAX_ITEMS=5000

# ----------------------------
# Storage
# ----------------------------
# Database backend: postgres | sqlite
# - postgres uses PG_* or DATABASE_URL below
# - if postgres config is missing, SQLite is used automatically
STORAGE_BACKEND=sqlite

# PostgreSQL (option A: full URL)
DATABASE_URL=

# PostgreSQL (option B: discrete fields)
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_SSL=false
PG_POOL_MAX=10
PG_CONNECTION_TIMEOUT_MS=10000

# SQLite fallback path
SQLITE_FILE=/data/watson.sqlite

UPLOAD_DIR=./uploads
MESSAGES_MEMORY_LIMIT=500

# Max upload size for multer (MB)
MAX_UPLOAD_MB=20

# ----------------------------
# Auto Reply (simple)
# ----------------------------
AUTO_REPLY_ENABLED=true

# dm | group | both
AUTO_REPLY_SCOPE=both

# contains | equals | regex
AUTO_REPLY_MATCH_TYPE=equals

# What triggers the reply
AUTO_REPLY_MATCH_VALUE=set_your_value_to_auto_reply

# Reply message text
AUTO_REPLY_TEXT=Hi 👋 Reply with "!bot help" in groups.

# Cooldown per chat (milliseconds)
AUTO_REPLY_COOLDOWN_MS=30000

# Group prefix required in groups (e.g. "!bot hi")
AUTO_REPLY_GROUP_PREFIX=!bot

# ----------------------------
# Queue / Throttling (anti-rate-limit)
# ----------------------------
WA_BASE_DELAY_MS=1200
WA_JITTER_MS=800
WA_PER_JID_GAP_MS=3000

# Retry behavior
WA_MAX_RETRIES=3
WA_RETRY_BACKOFF_MS=1500

# ----------------------------
# API Rate limiting (Express)
# ----------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

MEDIA_SIGNING_SECRET=change_me_to_a_secure_random_string
# Optional previous signing secret(s) during rotation (comma-separated)
MEDIA_SIGNING_SECRET_PREVIOUS=
MEDIA_URL_TTL_SECONDS=172800

# n8n forwarding
N8N_WEBHOOK_URL=n8n-webhook-url
N8N_SHARED_SECRET=change_me_to_a_secure_random_string

# optional: if you want group prefix mode default
N8N_GROUP_PREFIX=!bot

# Redis (durable outbound queue)
REDIS_URL=redis://redis:6379

# Queue naming (optional)
WA_QUEUE_NAME=wa-send

# If you want to hard-limit outbound pace centrally
WA_GLOBAL_MIN_GAP_MS=0
